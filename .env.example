# Ejemplo de variables de entorno
# Copia este archivo a .env.local para desarrollo local

# URL del API Backend
VITE_API_URL=https://backend-cepreuna-2025-production.up.railway.app/api

# Token JWT de apisperu (consulta de RUC). Obtener en https://apis.net.pe / apisperu.com
APISPERU_TOKEN=tu-token-jwt-aqui

# URL del Google Apps Script del forms-admin (despliegue /exec)
APPS_SCRIPT_URL=https://script.google.com/macros/s/XXXXX/exec
